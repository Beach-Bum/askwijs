    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "lucide-react": "^1.7.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.0",
